# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Ambiente virtual
.venv/
venv/
env/

# Logs e métricas geradas
logs/*
!logs/.gitkeep

# Relatórios gerados -- separados em relatorios/ (para o usuário: HTML,
# Excel, Markdown, CSV) e dados/ (contrato JSON interno entre motor e
# camada de relatório, não pensado para abrir direto).
output/*
!output/.gitkeep
!output/relatorios/
output/relatorios/*
!output/relatorios/.gitkeep
!output/relatorios/history/
output/relatorios/history/*
!output/relatorios/history/.gitkeep
!output/dados/
output/dados/*
!output/dados/.gitkeep

# Banco local do usuário e artefatos de coleta. Mesmo padrão de logs/ e
# output/: nada em data/ é versionado além do .gitkeep. A lista anterior
# enumerava artefatos por nome e vazava a cada nome novo -- os nomes são
# inventados por execução (research_universe_refresh_2930.csv, 552KB, escapou
# porque a regra cobria `research_universe_collection*`, não `_refresh_*`).
data/*
!data/.gitkeep

# Arquivos temporários do Excel
~$*.xlsx
~$*.xls

# Configurações locais e segredos
.env
.env.*
.claude/settings.local.json

# Posições reais da carteira pessoal (dado sensível, não versionado)
config/portfolio.csv
config/provider_secrets.json

# Editores e sistema operacional
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# Pacotes e relatórios temporários de desenvolvimento
Atlas_Source*.zip
TEST_REPORT_PR*.txt

# Pacotes locais de release
PR-*.zip
